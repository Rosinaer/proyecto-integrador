generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Rol {
  ADMIN
  RECEPCIONISTA
  TECNICO
  CLIENTE
}

enum EstadoTurno {
  PENDIENTE
  CONFIRMADO
  EN_PROCESO
  COMPLETADO
  CANCELADO
  AUSENTE
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

// --- MODELOS ---

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  apellido  String
  email     String   @unique
  password  String
  rol       Rol

  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente   Cliente?
  tecnico   Tecnico?

  @@index([email])
}

model Cliente {
  id        Int     @id @default(autoincrement())
  usuarioId Int     @unique
  telefono  String
  notas     String?

  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  turnos  Turno[]

  @@index([usuarioId])
}

model Tecnico {
  id           Int     @id @default(autoincrement())
  usuarioId    Int     @unique
  especialidad String?

  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario  Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  turnos   Turno[]
  horarios Horario[]

  @@index([usuarioId])
}

model Horario {
  id         Int       @id @default(autoincrement())
  tecnicoId  Int
  dia        DiaSemana
  horaInicio DateTime
  horaFin    DateTime

  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  tecnico Tecnico @relation(fields: [tecnicoId], references: [id], onDelete: Cascade)

  @@index([tecnicoId])
}

model Servicio {
  id              Int     @id @default(autoincrement())
  nombre          String
  duracionMinutos Int
  precio          Decimal @db.Decimal(10, 2)

  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  turnos Turno[]
}

model Turno {
  id         Int         @id @default(autoincrement())
  clienteId  Int
  tecnicoId  Int
  servicioId Int

  fechaInicio DateTime
  fechaFin    DateTime

  estado EstadoTurno @default(PENDIENTE)

  recordatorioEnviado Boolean @default(false)
  notas               String?

  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente  Cliente  @relation(fields: [clienteId], references: [id])
  tecnico  Tecnico  @relation(fields: [tecnicoId], references: [id])
  servicio Servicio @relation(fields: [servicioId], references: [id])

  pago Pago?

  @@index([tecnicoId, fechaInicio])
  @@index([clienteId])
}

model Pago {
  id        Int        @id @default(autoincrement())
  turnoId   Int        @unique
  monto     Decimal    @db.Decimal(10, 2)
  metodo    MetodoPago
  penalidad Boolean    @default(false)

  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  turno Turno @relation(fields: [turnoId], references: [id])

  @@index([turnoId])
}